# Local development environment.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Docker Compose reads `.env` automatically from the project root.

# OpenAI / Spring AI
# Used by the Spring app (application.properties -> spring.ai.openai.api-key).
OPENAI_API_KEY=replace-with-your-openai-api-key

# PostgreSQL (consumed by compose.yml for the `database` service).
# Defaults match the values hardcoded before, so the app keeps working
# out of the box if you don't override them.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=transaction

# Password reset email delivery (Resend)
RESEND_API_KEY=replace-with-your-resend-api-key
RESEND_SENDER=no-reply@mail.budgeting.online
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_TTL=30m
